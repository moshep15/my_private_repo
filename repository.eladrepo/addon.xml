<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.eladrepo" name="מאגר התוספים של אלעד" version="1.0.0" provider-name="Elad">
    <requires>
        <import addon="xbmc.addon" version="12.0.0"/>
    </requires>
    <extension point="xbmc.addon.repository" name="מאגר התוספים של אלעד">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/moshep15/repo-name/main/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/moshep15/repo-name/main/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/moshep15/repo-name/main/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>המאגר הרשמי לתוספי קודי שלי</summary>
        <description>כאן תוכלו למצוא עדכונים שוטפים לכל התוספים</description>
        <platform>all</platform>
    </extension>
</addon>