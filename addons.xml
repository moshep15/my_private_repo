<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>

<!-- תוסף מספר 1: הריפוזיטורי שלך -->
<addon id="repository.eladrepo" name="Elad Repository" version="1.0.0" provider-name="Elad">
    <requires>
        <import addon="xbmc.addon" version="19.0.0"/>
    </requires>
    <extension point="xbmc.addon.repository" name="Elad Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/moshep15/my_private_repo/main/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/moshep15/my_private_repo/main/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/moshep15/my_private_repo/main/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>המאגר הרשמי לתוספי קודי שלי</summary>
        <description>כאן תוכלו למצוא עדכונים שוטפים לכל התוספים</description>
        <platform>all</platform>
    </extension>
</addon>

<!-- תוסף מספר 2: תוסף הכתוביות המדויק שלך -->
<addon id="service.subtitles.kodipovilai" name="Kodi POV IL - AI Subtitles" version="0.2.137" provider-name="MoranTheKing">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.22.0"/>
    </requires>
    <extension point="xbmc.subtitle.module" library="default.py"/>
    <extension point="xbmc.service" library="service.py"/>
    <extension point="xbmc.addon.metadata">
        <reuselanguageinvoker>true</reuselanguageinvoker>
        <platform>all</platform>
        <language>en he</language>
        <license>MIT</license>
        <summary lang="he">תרגום AI לעברית של כתוביות, באמצעות Gemini API</summary>
        <description lang="he">מתרגם כתוביות מאנגלית לעברית בזמן אמת באמצעות Gemini של גוגל.</description>
    </extension>
</addon>

</addons>
