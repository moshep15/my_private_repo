<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>

<!-- תוסף מספר 1: הריפוזיטורי שלך -->
<addon id="repository.eladrepo" name="Elad Repository" version="1.0.0" provider-name="Elad">
    <requires>
        <import addon="xbmc.addon" version="12.0.0"/>
    </requires>
    <extension point="xbmc.addon.repository" name="Elad Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/moshep15/my_private_repo/main/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/moshep15/my_private_repo/main/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/moshep15/my_private_repo/main/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>המאגר הרשמי לתוספי קודי שלי</summary>
        <description>כאן תוכלו למצוא עדכונים שוטפים לכל התוספים</description>
        <platform>all</platform>
    </extension>
</addon>

<!-- תוסף מספר 2: תוסף הכתוביות שלך -->
<addon id="service.subtitles.kodipovilai" name="service.subtitles.kodipovilai" version="0.2.137" provider-name="Elad">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="addon.py">
        <provides>subtitles</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <summary>תוסף כתוביות לקודי</summary>
        <description>מאפשר הורדת כתוביות מתוך המאגר של אלעד</description>
    </extension>
</addon>

</addons>
