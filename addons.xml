<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>

<!-- תוסף 1: הריפוזיטורי שלך -->
<addon id="repository.eladrepo" name="Elad Repository" version="1.0.0" provider-name="Elad">
    <requires>
        <import addon="xbmc.addon" version="19.0.0"/>
    </requires>
    <extension point="xbmc.addon.repository" name="Elad Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/moshep15/my_private_repo/main/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/moshep15/my_private_repo/main/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/moshep15/my_private_repo/main/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>המאגר הרשמי לתוספי קודי שלי</summary>
        <description>כאן תוכלו למצוא עדכונים שוטפים לכל התוספים</description>
        <platform>all</platform>
    </extension>
</addon>

<!-- תוסף 2: תוסף הכתוביות AI שלך -->
<addon id="service.subtitles.kodipovilai" name="Kodi POV IL - AI Subtitles" version="0.2.169" provider-name="MoranTheKing">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.22.0"/>
    </requires>
    <extension point="xbmc.subtitle.module" library="default.py"/>
    <extension point="xbmc.service" library="service.py"/>
    <extension point="xbmc.addon.metadata">
        <reuselanguageinvoker>true</reuselanguageinvoker>
        <platform>all</platform>
        <language>en he</language>
        <license>MIT</license>
        <summary lang="he">תרגום AI לעברית של כתוביות, באמצעות Gemini API</summary>
        <description lang="he">מתרגם כתוביות מאנגלית לעברית בזמן אמת באמצעות Gemini של גוגל.</description>
    </extension>
</addon>

<!-- תוסף 3: תוסף ה-YouTube בגרסת הבטא -->
<addon id="plugin.video.youtube" name="YouTube" version="7.4.4+beta.2" provider-name="anxdpanic, bromix, MoojMidge">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.27.1"/>
        <import addon="inputstream.adaptive" version="19.0.0"/>
        <import addon="script.module.inputstreamhelper" version="0.2.2" optional="true"/>
        <import addon="script.module.pysocks" optional="true"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="resources/lib/plugin.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.service" library="resources/lib/service.py"/>
    <extension point="xbmc.python.module" library="resources/lib/"/>
    <extension point="xbmc.python.script" library="resources/lib/script.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <assets>
            <icon>resources/media/icon.png</icon>
            <fanart>resources/media/fanart.jpg</fanart>
        </assets>
        <platform>all</platform>
        <license>GPL-2.0-only</license>
        <forum>https://ytaddon.panicked.xyz/forum</forum>
        <website>https://www.youtube.com</website>
        <source>https://github.com/anxdpanic/plugin.video.youtube</source>
        <reuselanguageinvoker>true</reuselanguageinvoker>
        <summary lang="en_GB">Plugin for YouTube</summary>
        <summary lang="he_IL">תוסף עבור YouTube</summary>
        <description lang="en_GB">YouTube is one of the biggest video-sharing websites of the world.</description>
        <description lang="he_IL">YouTube הוא אחד מאתרי שיתוף הווידאו הגדולים בעולם.</description>
    </extension>
</addon>

<!-- תוסף 4: הויזארד החדש שלך (Kodi POV IL Wizard) -->
<addon id="plugin.program.kodipovilwizard" name="[COLOR yellow]Kodi POV IL Wizard[/COLOR]" version="0.1.30" provider-name="MoranTheKing">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
        <import addon="script.module.requests" />
        <import addon="script.module.six" />
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.service" library="startup.py" start="startup" />
    <extension point="xbmc.addon.metadata">
        <summary lang="en">[COLOR blue]Kodi POV IL Wizard[/COLOR]</summary>
        <description lang="en">Installs the Kodi POV IL FENtastic test build.</description>
        <platform>all</platform>
        <reuselanguageinvoker>false</reuselanguageinvoker>
        <source>https://www.github.com/a4k-openproject/plugin.program.openwizard/</source>
        <assets>
            <icon>icon.jpg</icon>
            <fanart>fanart.png</fanart>
        </assets>
    </extension>
</addon>

</addons>
